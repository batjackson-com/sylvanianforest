---
# This ONE template generates one static HTML page per DB row.
# `pagination` walks the `characters` global (from src/_data/characters.js),
# and `permalink` decides each page's URL from that row's data.
layout: base.njk
pagination:
  data: characters
  size: 1
  alias: character
permalink: "/characters/{{ character.slug }}/"
eleventyComputed:
  title: "{{ character.name }}"
---
<article class="character">
  <p class="crumbs"><a href="/">Home</a> / {{ character.family }}</p>
  <h1>{{ character.name }}</h1>
  <p class="meta">
    <span>{{ character.species }}</span> ·
    <span>{{ character.family }} family</span> ·
    <span>{{ character.year }}</span>
  </p>
  <p>{{ character.description }}</p>
</article>
