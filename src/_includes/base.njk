<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title }} · Sylvanian Forest</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/assets/style.css" />
  </head>
  <body>
    <header>
      <div class="bar">
        <a href="/" class="brand">
          <img class="logo" src="/assets/logo.jpg" alt="" width="120" height="120" />
          <span>Sylvanian&nbsp;Forest</span>
        </a>
        <span class="tagline">Retro &amp; modern Sylvanian&nbsp;collectibles</span>
        <nav class="mainnav" aria-label="Set types">
          {% for type in setTypes %}
          <a href="/types/{{ type.slug }}/">{{ type.name }}</a>
          {% endfor %}
        </nav>
      </div>
    </header>
    <main>
      {{ content | safe }}
    </main>
    <footer>
      <p>Retro &amp; modern Sylvanian Families collectibles.</p>
    </footer>
  </body>
</html>
