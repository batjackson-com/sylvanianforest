---
# This ONE template generates one static HTML page per DB row.
# `pagination` walks the `sets` global (from src/_data/sets.js),
# and `permalink` decides each page's URL from that row's data.
layout: base.njk
pagination:
  data: sets
  size: 1
  alias: set
permalink: "/sets/{{ set.slug }}/"
eleventyComputed:
  title: "{{ set.name }}"
---
<article class="set">
  <p class="crumbs"><a href="/">Home</a> / {{ set.family }}</p>
  <h1>{{ set.name }}</h1>
  <p class="meta">
    <span>{{ set.brand }}</span> ·
    <span>{{ set.species }}</span> ·
    <span>{{ set.family }} family</span> ·
    <span>{{ set.year }}</span>
  </p>
  {% if set.setType %}<p class="set-type">Type: <a href="/types/{{ set.typeSlug }}/">{{ set.setType }}</a></p>{% endif %}
  {% if set.setId %}<p class="set-id">Set ID: <code>{{ set.setId }}</code></p>{% endif %}

  {% if set.tags.length %}
  <ul class="tags">
    {% for tag in set.tags %}<li class="tag">{{ tag }}</li>{% endfor %}
  </ul>
  {% endif %}

  {% if set.photos.length %}
  <ul class="photos">
    {% for photo in set.photos %}
    <li>
      <img src="/assets/sets/{{ photo.filename }}" alt="{{ photo.caption or set.name }}"
           width="400" height="300" loading="lazy" />
      {% if photo.caption %}<figcaption>{{ photo.caption }}</figcaption>{% endif %}
    </li>
    {% endfor %}
  </ul>
  {% endif %}

  <p>{{ set.description }}</p>
</article>
