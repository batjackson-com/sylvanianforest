---
# This ONE template generates one static HTML page per DB row.
# `pagination` walks the `sets` global (from src/_data/sets.js),
# and `permalink` decides each page's URL from that row's data.
layout: base.njk
pagination:
  data: sets
  size: 1
  alias: set
permalink: "/sets/{{ set.slug }}/"
eleventyComputed:
  title: "{{ set.name }}"
---
<article class="set">
  <p class="crumbs"><a href="/">Home</a> / {{ set.family }}</p>
  <h1>{{ set.name }}</h1>
  <p class="meta">
    <span>{{ set.brand }}</span>
    {% if set.species %} · <span>{{ set.species }}</span>{% endif %}
    {% if set.family %} · <span>{{ set.family }} family</span>{% endif %}
    {% if set.company %} · <span>{{ set.company }}</span>{% endif %}
    {% if set.country %} · <span>{{ set.country }}</span>{% endif %}
    {% if set.year %} · <span>{{ set.year }}</span>{% endif %}
    {% if set.setId %} · <span class="set-id"><code>{{ set.setId }}</code></span>{% endif %}
  </p>

  {% if set.tags.length %}
  <div class="tags-block">
    <span class="tags-label">Tags:</span>
    <ul class="tags">
      {% for tag in set.tags %}<li class="tag"><a href="/tags/{{ tag | slugify }}/">{{ tag }}</a></li>{% endfor %}
    </ul>
  </div>
  {% endif %}

  {% if set.photos.length %}
  <ul class="photos">
    {% for photo in set.photos %}
    <li>
      <img src="/assets/sets/{{ photo.filename }}" alt="{{ photo.caption or set.name }}"
           width="400" height="300" loading="lazy" />
      {% if photo.caption %}<figcaption>{{ photo.caption }}</figcaption>{% endif %}
    </li>
    {% endfor %}
  </ul>
  {% endif %}

  <p>{{ set.description }}</p>
</article>
