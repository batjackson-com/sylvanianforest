---
layout: base.njk
title: Home
---
<h1>Sylvanian Forest</h1>
<p>{{ characters | length }} characters, one page each.</p>

<ul class="grid">
  {% for character in characters %}
  <li>
    <a href="/characters/{{ character.slug }}/">
      <strong>{{ character.name }}</strong>
      <span>{{ character.species }} · {{ character.year }}</span>
    </a>
  </li>
  {% endfor %}
</ul>
