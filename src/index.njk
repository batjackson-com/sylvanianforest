---
layout: base.njk
title: Home
---
<h1>Sylvanian Forest</h1>
<p>{{ sets | length }} sets, one page each.</p>

<ul class="grid">
  {% for set in sets %}
  <li>
    <a href="/sets/{{ set.slug }}/">
      {% if set.photos.length %}
      <img class="thumb" src="/assets/sets/{{ set.photos[0].filename }}" alt=""
           width="400" height="300" loading="lazy" />
      {% endif %}
      <strong>{{ set.name }}</strong>
      <span>{{ set.brand }} · {{ set.year }}</span>
    </a>
  </li>
  {% endfor %}
</ul>
